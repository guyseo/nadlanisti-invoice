# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# EZCount
EZCOUNT_API_KEY=your_api_key
EZCOUNT_API_USER=your@email.com

# Google OAuth (Gmail + Google Ads)
GOOGLE_OAUTH_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-...
GOOGLE_REFRESH_TOKEN=1//...

# Gmail
GMAIL_USER_EMAIL=guy@yourdomain.co.il

# Google Ads (Session 8)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Facebook Ads (Session 8)
FACEBOOK_ACCESS_TOKEN=

# Cron security
CRON_SECRET=replace_with_32_char_random_string

# Feature flags
AUTO_CC_ENABLED=false

# App URL (for emails)
NEXT_PUBLIC_APP_URL=http://localhost:2000
